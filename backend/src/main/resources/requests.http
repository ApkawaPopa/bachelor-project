### Получить публичные ключи пользователей по username
GET http://{{host}}:{{port}}/api/v1/user/keys
Content-Type: application/json
Authorization: Bearer {{jwt}}

{
  "usernames": [
    {
      "username": "test_user1"
    },
    {
      "username": "test_user2"
    },
    {
      "username": "test_user3"
    }
  ]
}

